{
  "routes": [
    { "route": "/login", "allowedRoles": ["anonymous", "authenticated"] },

    { "route": "/api/*", "allowedRoles": ["authenticated"] },

    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/login", "statusCode": 302 },
    "403": { "redirect": "/login", "statusCode": 302 }
  },
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/b37ebafe-236c-42d0-a008-001f9e6c4a08/v2.0",
          "clientIdSettingName": "ENTRA_CLIENT_ID",
          "clientSecretSettingName": "ENTRA_CLIENT_SECRET"
        }
      }
    }
  }
}