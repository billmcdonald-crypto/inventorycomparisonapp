{
  "routes": [
    { "route": "/login", "allowedRoles": ["anonymous", "authenticated"] },

    { "route": "/api/health", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/rolesping", "allowedRoles": ["anonymous", "authenticated"] },

    { "route": "/api/roles-source", "allowedRoles": ["anonymous", "authenticated"] },

    { "route": "/api/*", "allowedRoles": ["internal", "bike", "rt", "ashworth"] },

    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/login", "statusCode": 302 },
    "403": { "redirect": "/login", "statusCode": 302 }
  },
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/<tenant>/v2.0",
          "clientIdSettingName": "ENTRA_CLIENT_ID",
          "clientSecretSettingName": "ENTRA_CLIENT_SECRET"
        }
      }
    },
    "rolesSource": "/api/roles-source"
  }
}